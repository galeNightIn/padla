---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A fast, font-free blog.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/">padla</a>
      <nav><a href="/">posts</a></nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
